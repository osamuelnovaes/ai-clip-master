# AI-Clip-Master — Security Configuration

# API Keys (Get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# TikTok Automation (Export as cookies.txt)
TIKTOK_COOKIES_CONTENT=your_cookies_text_here

# YouTube Data API v3 (OAuth JSON content)
YOUTUBE_CLIENT_SECRETS=your_oauth_json_content_here
YOUTUBE_TOKEN=your_token_json_content_here

# Processing Settings
MODEL_SIZE=tiny
CLIPPING_COUNT=3
VIDEO_QUALITY=720p
